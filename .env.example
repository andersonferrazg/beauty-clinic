# Copiar este arquivo para .env e preencher os valores

# Banco de dados (produção = postgresql, desenvolvimento = sqlite)
DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Segredo da sessão — gerar uma string aleatória longa (mínimo 32 caracteres)
# Exemplo: openssl rand -hex 32
SESSION_SECRET="coloque-aqui-um-segredo-aleatorio-longo"
