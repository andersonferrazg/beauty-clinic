generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  nome        String
  slug        String   @unique
  cnpj        String?
  telefone    String?
  endereco    String?
  logoUrl     String?
  corPrimaria String   @default("#B89968")
  corSecundaria String @default("#E8DCC4")
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())

  usuarios             Usuario[]
  profissionais        Profissional[]
  clientes             Cliente[]
  servicos             Servico[]
  produtos             Produto[]
  agendamentos         Agendamento[]
  statusAgenda         StatusAgenda[]
  mensagensWpp         MensagemWpp[]
  despesas             Despesa[]
  lancamentos          Lancamento[]
  configuracoes        TenantConfig?
  prontuarios          Prontuario[]
  comissoes            ComissaoLancamento[]
  movimentacoesEstoque MovimentacaoEstoque[]
  orcamentos           Orcamento[]
  leads                Lead[]
  mensagensPredefinidas MensagemPredefinida[]
  notificacoes         NotificacaoSistema[]
  formasPagamento      FormaPagamento[]

  @@map("tenants")
}

model TenantConfig {
  id                     String  @id @default(cuid())
  tenantId               String  @unique
  intervaloAgendaMin     Int     @default(30)
  horaInicioAgenda       Int     @default(6)
  horaFimAgenda          Int     @default(21)
  whatsappAtivo          Boolean @default(false)
  horarioEnvioWpp        String  @default("08:00")
  toleranciaAtrasoMin    Int     @default(10)
  agendamentoOnlineAtivo Boolean @default(false)
  mensagemConfirmacaoWpp String?
  mensagemAniversarioWpp String?
  urlNFSe                String?
  emailNotificacoes      String?
  notificarPorEmail      Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

model Usuario {
  id             String   @id @default(cuid())
  tenantId       String
  nome           String
  email          String
  senhaHash      String
  ativo          Boolean  @default(true)
  criadoEm      DateTime @default(now())

  profissionalId String?  @unique
  profissional   Profissional? @relation(fields: [profissionalId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissoes     UsuarioPermissao?
  logsAcesso     LogAcesso[]

  @@unique([tenantId, email])
  @@map("usuarios")
}

model UsuarioPermissao {
  id                        String  @id @default(cuid())
  usuarioId                 String  @unique
  isAdmin                   Boolean @default(false)
  verAgenda                 Boolean @default(true)
  realizarAgendamentos      Boolean @default(true)
  verContatoCliente         Boolean @default(true)
  verValoresServicos        Boolean @default(true)
  acessarClientes           Boolean @default(false)
  acessarServicos           Boolean @default(false)
  acessarProdutos           Boolean @default(false)
  acessarDespesas           Boolean @default(false)
  acessarFinanceiro         Boolean @default(false)
  verComissoesReceber       Boolean @default(false)
  verPagamentosComissao     Boolean @default(false)
  acessarProntuarios        Boolean @default(false)
  acessarRelatorios         Boolean @default(false)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("usuario_permissoes")
}

model LogAcesso {
  id        String   @id @default(cuid())
  usuarioId String
  acao      String
  recurso   String
  ip        String?
  criadoEm DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("logs_acesso")
}

// ─── Profissionais ────────────────────────────────────────────────────────────

model Profissional {
  id             String           @id @default(cuid())
  tenantId       String
  nome           String
  email          String?
  telefone       String?
  especialidade  String?
  avatarUrl      String?
  tipoComissao   String           @default("PERCENTUAL") // PERCENTUAL | SALARIO_FIXO | MISTO | INTEGRAL
  percentualComissao Float?
  salarioFixo    Float?
  cor            String           @default("#B89968")
  whatsappSessao String?
  whatsappAtivo  Boolean          @default(false)
  registro           String?
  cpf                String?
  cnpj               String?
  direcaoComissao    String  @default("CLINICA_PAGA")
  frequenciaComissao String  @default("MENSAL") // DIARIA | SEMANAL | QUINZENAL | MENSAL
  comissaoSobre      String  @default("BRUTO") // BRUTO | LIQUIDO
  possuiAgenda              Boolean @default(true)
  profissionalTerceiro      Boolean @default(false)
  agendamentoOnlineAtivo    Boolean @default(false)
  emailNotificacoes         String?
  ativo              Boolean @default(true)
  criadoEm        DateTime         @default(now())

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario          Usuario?
  agendamentos     Agendamento[]
  bloqueios        Bloqueio[]
  procedimentos    Procedimento[]
  comissoes        ComissaoLancamento[]
  orcamentos       Orcamento[]
  leads            Lead[]
  disponibilidades     DisponibilidadeProfissional[]
  disponibilidadesData DisponibilidadeData[]

  @@unique([tenantId, email])
  @@map("profissionais")
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Cliente {
  id               String   @id @default(cuid())
  tenantId         String
  nome             String
  telefone1        String?
  telefone2        String?
  email            String?
  cpf              String?
  rg               String?
  sexo             String?
  dataNascimento   DateTime?
  endereco         String?
  observacao       String?
  telefone1Pendente Boolean @default(false)
  ativo            Boolean  @default(true)
  criadoEm        DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  prontuario   Prontuario?
  orcamentos   Orcamento[]
  leads        Lead[]

  @@index([tenantId, telefone1])
  @@index([tenantId, cpf])
  @@index([tenantId, dataNascimento])
  @@map("clientes")
}

// ─── Serviços ─────────────────────────────────────────────────────────────────

model Servico {
  id           String   @id @default(cuid())
  tenantId     String
  nome         String
  categoria    String?
  cor          String   @default("#B89968")
  duracaoMin   Int      @default(60)
  preco        Float    @default(0)
  custoMaterial Float?
  descricao    String?
  precoVariavel Boolean @default(false)
  disponivelOnline Boolean @default(false)
  produtoConsumidoId String?
  qtdConsumida       Int?    @default(1)
  ativo        Boolean  @default(true)
  criadoEm    DateTime @default(now())

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itensAgendamento    ItemAgendamento[]
  itensOrcamento      ItemOrcamento[]
  produtoConsumido    Produto?             @relation("ServicoConsome", fields: [produtoConsumidoId], references: [id])

  @@map("servicos")
}

// ─── Agendamentos ─────────────────────────────────────────────────────────────

model StatusAgenda {
  id              String  @id @default(cuid())
  tenantId        String
  nome            String
  cor             String  @default("#cccccc")
  contaConfirmado Boolean @default(false)
  ordem           Int     @default(0)
  sistemico       Boolean @default(false)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]

  @@map("status_agenda")
}

model Agendamento {
  id                    String    @id @default(cuid())
  tenantId              String
  profissionalId        String
  clienteId             String?
  statusId              String?
  inicio                DateTime
  fim                   DateTime
  corCustom             String?
  observacao            String?
  recorrenciaGrupoId    String?
  confirmacaoWppEnviada Boolean   @default(false)
  confirmacaoWppRespondida Boolean @default(false)
  confirmacaoManualPendente Boolean @default(false)
  valorTotal            Float?
  formaPagamento        String?
  dataRealizado         DateTime?
  lancamentoId          String?   @unique
  origem                String?   // "manual" | "online"
  criadoEm             DateTime  @default(now())
  atualizadoEm         DateTime  @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profissional  Profissional      @relation(fields: [profissionalId], references: [id])
  cliente       Cliente?          @relation(fields: [clienteId], references: [id])
  status        StatusAgenda?     @relation(fields: [statusId], references: [id])
  lancamento    Lancamento?       @relation("AgendamentoReceita", fields: [lancamentoId], references: [id])
  itens         ItemAgendamento[]
  mensagensWpp  MensagemWpp[]
  movimentacoes MovimentacaoEstoque[]
  orcamento     Orcamento?        @relation("OrcamentoAgendamento")

  @@index([tenantId, inicio])
  @@index([tenantId, profissionalId, inicio])
  @@map("agendamentos")
}

model ItemAgendamento {
  id            String  @id @default(cuid())
  agendamentoId String
  servicoId     String?
  produtoId     String?
  preco         Float
  quantidade    Int     @default(1)

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  servico     Servico?    @relation(fields: [servicoId], references: [id])
  produto     Produto?    @relation(fields: [produtoId], references: [id])

  @@map("itens_agendamento")
}

model Bloqueio {
  id             String   @id @default(cuid())
  tenantId       String
  profissionalId String
  inicio         DateTime
  fim            DateTime
  motivo         String?
  criadoEm      DateTime @default(now())

  profissional Profissional @relation(fields: [profissionalId], references: [id])

  @@map("bloqueios")
}

// ─── WhatsApp ────────────────────────────────────────────────────────────────

model MensagemWpp {
  id            String    @id @default(cuid())
  tenantId      String
  agendamentoId String?
  telefone      String
  tipo          String    // CONFIRMACAO | LEMBRETE | CANCELAMENTO | MANUAL | ANIVERSARIO
  conteudo      String
  enviadaEm    DateTime?
  resposta      String?
  statusEnvio   String    @default("PENDENTE") // PENDENTE | ENVIADA | ENTREGUE | LIDA | FALHOU
  criadoEm     DateTime  @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agendamento  Agendamento? @relation(fields: [agendamentoId], references: [id])

  @@map("mensagens_wpp")
}

// ─── Produtos ─────────────────────────────────────────────────────────────────

model Produto {
  id            String   @id @default(cuid())
  tenantId      String
  nome          String
  categoria     String?
  precoVenda    Float    @default(0)
  precoCusto    Float?
  qtdEstoque    Int      @default(0)
  qtdMinima     Int      @default(0)
  patrimonio    Boolean  @default(false)
  dataValidade  DateTime?
  ativo         Boolean  @default(true)
  ehInjetavel   Boolean  @default(false)        // aparece na paleta do planejador visual
  unidadeMedida String?  @default("unidade")    // "ui" | "ml" | "unidade" | "un"
  corMarcacao   String?  @default("#A78BFA")    // cor do ponto no canvas (hex)
  criadoEm      DateTime @default(now())

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movimentacoes        MovimentacaoEstoque[]
  itensAgendamento     ItemAgendamento[]
  itensOrcamento       ItemOrcamento[]
  servicosConsumidores Servico[]             @relation("ServicoConsome")

  @@map("produtos")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model Lancamento {
  id              String    @id @default(cuid())
  tenantId        String
  tipo            String    // RECEITA | DESPESA
  categoria       String?
  descricao       String
  valor           Float     // líquido (após taxa, se houver); igual ao bruto quando sem taxa
  valorBruto      Float?    // valor original antes da taxa (null = sem taxa)
  taxa            Float?    // R$ absoluto de taxa descontada
  percentualTaxa  Float?    // % aplicado
  vencimento      DateTime?
  pagoEm          DateTime?
  pago            Boolean   @default(false)
  recorrencia     String?   // MENSAL | SEMANAL | ANUAL
  formaPagamento  String?
  origem          String?   // AUTO_ATENDIMENTO | AUTO_RECORRENCIA | AUTO_COMISSAO | MANUAL
  criadoEm        DateTime  @default(now())

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agendamento         Agendamento?         @relation("AgendamentoReceita")
  comissoesOrigem     ComissaoLancamento[] @relation("ReceitaOrigem")
  comissoesLiquidadas ComissaoLancamento[] @relation("DespesaPagamento")

  @@index([tenantId, criadoEm])
  @@index([tenantId, vencimento])
  @@map("lancamentos")
}

model Despesa {
  id         String    @id @default(cuid())
  tenantId   String
  descricao  String
  categoria  String?
  valor      Float
  tipo       String    @default("REGULAR") // REGULAR | FIXA_MENSAL | PARCELADA
  vencimento DateTime?
  pagoEm    DateTime?
  pago       Boolean   @default(false)
  criadoEm  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("despesas")
}

// ─── Prontuários (Fase 2) ─────────────────────────────────────────────────────

model Prontuario {
  id        String   @id @default(cuid())
  tenantId  String
  clienteId String   @unique
  criadoEm DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente       Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  procedimentos Procedimento[]

  @@map("prontuarios")
}

model Procedimento {
  id                    String   @id @default(cuid())
  tenantId              String
  prontuarioId          String
  profissionalId        String
  data                  DateTime
  tipo                  String   // Botox | Preenchimento Lábios | Rinomodelação | Harmonização | Outro
  descricao             String?
  produtosUsados        String?
  anamnese              String?  // JSON serializado com respostas
  assinaturaPaciente    String?  // PNG base64
  assinaturaProfissional String? // PNG base64
  termoAceito           Boolean  @default(false)
  criadoEm             DateTime @default(now())
  atualizadoEm         DateTime @updatedAt

  prontuario   Prontuario   @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
  profissional Profissional @relation(fields: [profissionalId], references: [id])
  fotos        Foto[]

  @@map("procedimentos")
}

model Foto {
  id             String   @id @default(cuid())
  tenantId       String
  procedimentoId String
  url            String
  tag            String   // antes | durante | depois
  descricao      String?
  criadoEm      DateTime @default(now())

  procedimento Procedimento @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)

  @@map("fotos")
}

// ─── Comissões e Estoque (Fase 3) ─────────────────────────────────────────────

model ComissaoLancamento {
  id                    String    @id @default(cuid())
  tenantId              String
  lancamentoId          String    // RECEITA que originou a comissão
  profissionalId        String
  valorBase             Float     // valor do atendimento que serviu de base
  percentual            Float?    // % aplicado (null se SALARIO_FIXO/INTEGRAL)
  valorComissao         Float     // resultado a pagar para a profissional
  pago                  Boolean   @default(false)
  pagoEm                DateTime?
  lancamentoPagamentoId String?   // DESPESA criada ao pagar a comissão
  direcaoComissao       String    @default("CLINICA_PAGA")
  criadoEm              DateTime  @default(now())

  lancamento          Lancamento   @relation("ReceitaOrigem", fields: [lancamentoId], references: [id], onDelete: Cascade)
  lancamentoPagamento Lancamento?  @relation("DespesaPagamento", fields: [lancamentoPagamentoId], references: [id])
  profissional        Profissional @relation(fields: [profissionalId], references: [id])
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, criadoEm])
  @@index([tenantId, profissionalId, criadoEm])
  @@map("comissoes_lancamento")
}

model MovimentacaoEstoque {
  id            String   @id @default(cuid())
  tenantId      String
  produtoId     String
  agendamentoId String?  // null se ajuste manual
  tipo          String   // ENTRADA | SAIDA | AJUSTE
  quantidade    Int      // sempre positivo; tipo determina o efeito no estoque
  motivo        String?
  custoUnitario Float?
  criadoEm     DateTime @default(now())

  produto     Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  agendamento Agendamento? @relation(fields: [agendamentoId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("movimentacoes_estoque")
}

// ─── Orçamentos ───────────────────────────────────────────────────────────────

model Orcamento {
  id             String   @id @default(cuid())
  tenantId       String
  clienteId      String
  profissionalId String?
  status         String   @default("EM_ABERTO") // EM_ABERTO | APROVADO | FECHADO | CANCELADO | EXPIRADO
  dataValidade   DateTime
  valorTotal     Float    @default(0)
  observacao     String?
  agendamentoId  String?  @unique
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente      Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  profissional Profissional?   @relation(fields: [profissionalId], references: [id])
  agendamento  Agendamento?    @relation("OrcamentoAgendamento", fields: [agendamentoId], references: [id])
  itens        ItemOrcamento[]
  interacoes   InteracaoOrcamento[]

  @@index([tenantId, status])
  @@index([clienteId])
  @@map("orcamentos")
}

model ItemOrcamento {
  id          String  @id @default(cuid())
  orcamentoId String
  servicoId   String?
  produtoId   String?
  preco       Float
  quantidade  Int     @default(1)
  descricao   String?

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  servico   Servico?  @relation(fields: [servicoId], references: [id])
  produto   Produto?  @relation(fields: [produtoId], references: [id])

  @@map("itens_orcamento")
}

model InteracaoOrcamento {
  id          String   @id @default(cuid())
  orcamentoId String
  tipo        String   // LIGACAO | WHATSAPP | NOTA
  texto       String
  criadoEm   DateTime @default(now())

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("interacoes_orcamento")
}

// ─── CRM / Pipeline de Leads ─────────────────────────────────────────────────

model Lead {
  id               String   @id @default(cuid())
  tenantId         String
  nome             String
  telefone         String?
  email            String?
  origem           String?  // INSTAGRAM | WHATSAPP | INDICACAO | SITE | OUTRO
  servicoInteresse String?
  profissionalId   String?
  estagio          String   @default("NOVO") // NOVO | EM_CONTATO | AGENDADO | CONVERTIDO | PERDIDO
  clienteId        String?
  observacoes      String?
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profissional Profissional?  @relation(fields: [profissionalId], references: [id])
  cliente      Cliente?       @relation(fields: [clienteId], references: [id])
  interacoes   InteracaoLead[]

  @@index([tenantId, estagio])
  @@map("leads")
}

model InteracaoLead {
  id        String   @id @default(cuid())
  leadId    String
  tipo      String   // NOTA | LIGACAO | WHATSAPP | EMAIL
  texto     String
  criadoEm  DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("interacoes_lead")
}

model MensagemPredefinida {
  id        String   @id @default(cuid())
  tenantId  String
  nome      String
  texto     String
  ordem     Int      @default(0)
  criadaEm  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("mensagens_predefinidas")
}

// ─── Disponibilidade dos Profissionais (Agendamento Online) ───────────────────

model DisponibilidadeProfissional {
  id             String @id @default(cuid())
  tenantId       String
  profissionalId String
  diaSemana      Int    // 0=domingo, 1=segunda, 2=terça, 3=quarta, 4=quinta, 5=sexta, 6=sábado
  horaInicio     Int    // ex: 9 representa 09:00
  horaFim        Int    // ex: 18 representa 18:00

  horaInicio2    Int?   // início do 2º período (ex: tarde)
  horaFim2       Int?   // fim do 2º período

  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@unique([profissionalId, diaSemana])
  @@index([tenantId])
  @@map("disponibilidades_profissional")
}

model DisponibilidadeData {
  id             String   @id @default(cuid())
  tenantId       String
  profissionalId String
  data           DateTime // data específica (armazenada como meio-dia UTC)
  tipo           String   // "DISPONIVEL" | "BLOQUEADO"
  horaInicio     Int?
  horaFim        Int?
  horaInicio2    Int?
  horaFim2       Int?

  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@unique([profissionalId, data])
  @@index([tenantId])
  @@map("disponibilidades_data")
}

// ─── Formas de Pagamento ──────────────────────────────────────────────────────

model FormaPagamento {
  id             String  @id @default(cuid())
  tenantId       String
  nome           String
  percentualTaxa Float   @default(0)
  ativa          Boolean @default(true)
  ordem          Int     @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("formas_pagamento")
}

// ─── Notificações do Sistema (Agendamento Online) ─────────────────────────────

model NotificacaoSistema {
  id           String   @id @default(cuid())
  tenantId     String
  tipo         String   // "AGENDAMENTO_ONLINE"
  titulo       String
  descricao    String?
  linkRelativo String?  // ex: "/agenda?data=2026-05-30&abrir=cxyz"
  lida         Boolean  @default(false)
  criadaEm     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, lida])
  @@map("notificacoes_sistema")
}
